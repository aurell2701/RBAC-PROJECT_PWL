<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
<div class="flex min-h-screen">
  <%- include('../layouts/sidebar') %>
  <div class="flex-1 flex flex-col">
    <%- include('../layouts/header') %>
    <main class="p-6 flex-1">
      <div class="bg-white rounded shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Daftar User</h2>
        <form method="POST" action="/users" class="mb-6 flex gap-3">
          <input name="username" placeholder="Username" required class="border rounded px-3 py-2 flex-1">
          <input name="password" placeholder="Password" required class="border rounded px-3 py-2 flex-1">
          <select name="role_id" class="border rounded px-3 py-2">
            <% roles.forEach(function(r) { %>
              <option value="<%= r.id %>"><%= r.name %></option>
            <% }) %>
          </select>
          <button class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Tambah</button>
        </form>
        <table class="w-full text-sm border-collapse">
          <thead class="bg-gray-100">
            <tr>
              <th class="p-3 text-left border">ID</th>
              <th class="p-3 text-left border">Username</th>
              <th class="p-3 text-left border">Role ID</th>
              <th class="p-3 text-left border">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
            <tr class="hover:bg-gray-50">
              <td class="p-3 border"><%= u.id %></td>
              <td class="p-3 border"><%= u.username %></td>
              <td class="p-3 border"><%= u.role_id %></td>
              <td class="p-3 border">
                <form method="POST" action="/users/<%= u.id %>/delete">
                  <button class="bg-red-500 text-white px-3 py-1 rounded text-xs hover:bg-red-600">Hapus</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
    <%- include('../layouts/footer') %>
  </div>
</div>
</body>
</html>